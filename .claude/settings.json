{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -q '/src/main/resources/db/migration/.*\\.sql$' && (cd \"$CLAUDE_PROJECT_DIR\" && ./gradlew generateJooq) || true",
            "timeout": 180,
            "statusMessage": "Regenerating jOOQ sources from migrations..."
          }
        ]
      }
    ]
  }
}